# ScoreScribe backend environment variables
# Copy to .env and edit as needed:  cp .env.example .env

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/scorescribe/uploads
OUTPUT_DIR=/tmp/scorescribe/outputs

# ── Public base URL (used in download URLs returned to Flutter) ────────────────
# Local dev:
BASE_URL=http://localhost:8000
# Production: set to your deployed domain, e.g.
# BASE_URL=https://api.scorescribe.example.com

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Demucs model ───────────────────────────────────────────────────────────────
# htdemucs      = 4-stem (drums/bass/vocals/other)  — fastest
# htdemucs_6s   = 6-stem (adds guitar + piano)      — more detail
# mdx_extra     = alternative 4-stem model
DEMUCS_MODEL=htdemucs

# ── Basic Pitch defaults ───────────────────────────────────────────────────────
ONSET_THRESHOLD=0.5
FRAME_THRESHOLD=0.3
MIN_NOTE_LENGTH_MS=58

# ── Upload limits ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=200
